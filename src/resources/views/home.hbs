<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-6">
      {{#if msg}}
        <div class="alert alert-success" role="alert">
          {{msg}}
        </div>
      {{/if}}
      <form action="/upload" enctype="multipart/form-data" method="POST">
        <div class="form-group mb-3">
          <label for="myImage" class="form-label">Choose an image to upload</label>
          <input type="file" class="form-control" name="myImage" accept="image/*" required>
        </div>
        <div class="d-grid">
          <button type="submit" class="btn btn-primary">Predict</button>
        </div>
      </form>
      <div class="mt-3">
        <a href="/profile" class="card-link">My Profile</a>
        <a href="/auth/logout" class="card-link">Logout</a>
      </div>
    </div>
  </div>
</div>